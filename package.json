{
  "name": "keyv-filesystem",
  "version": "1.0.0-rc.9",
  "description": "Filesystem storage adapter for Keyv, optimized for binary data, using one file per item.",
  "main": "lib/index.js",
  "type": "module",
  "types": "./lib/index.d.ts",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "tsc && rimraf ./node_modules/.cache && vitest run",
    "demo": "node --experimental-strip-types demo/demo.ts",
    "preversion": "npm run format:check && npm test",
    "postversion": "git add --all && git push origin main --tags"
  },
  "files": [
    "lib"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/erkstruwe/keyv-filesystem.git"
  },
  "keywords": [
    "keyv",
    "filesystem",
    "binary",
    "cache"
  ],
  "author": "Erk Struwe <erk.struwe.hb+keyv-filesystem@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/erkstruwe/keyv-filesystem/issues"
  },
  "homepage": "https://github.com/erkstruwe/keyv-filesystem#readme",
  "engines": {
    "node": ">=16.8.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1"
  },
  "devDependencies": {
    "@keyv/serialize": "^1.1.1",
    "@keyv/test-suite": "^2.1.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.4",
    "keyv": "^5.5.3",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "volta": {
    "node": "24.16.0"
  }
}
